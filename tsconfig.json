{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "types": ["@cloudflare/workers-types", "vite/client", "node"],
    "skipLibCheck": true
  },
  "include": [
    "src",
    "functions",
    "ingest",
    "scripts",
    "tests",
    "vite.config.ts",
    "playwright.config.ts"
  ]
}
